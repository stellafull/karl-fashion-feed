# LLM / search providers
OPENROUTER_API_KEY="your-openrouter-api-key"
DASHSCOPE_API_KEY="your-dashscope-api-key"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional legacy / compatibility settings still referenced in parts of the repo
MILVUS_URI="localhost:19530"
MILVUS_TOKEN="root:Milvus"

# External infrastructure (the app-only docker compose expects these to already exist)
QDRANT_URL="http://your-qdrant-host:6333"
REDIS_HOST="your-redis-host"
REDIS_PORT=6379
REDIS_USER="karl"
REDIS_PASSWORD="your-redis-password"
POSTGRES_HOST="your-postgres-host"
POSTGRES_PORT=5432
POSTGRES_USER="karl"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_DB="karlfeed"

# Search APIs
BRAVE_API_KEY="your-brave-api-key"
TAVILY_API_KEY="your-tavily-api-key"

# Auth
AUTH_JWT_SECRET="replace-with-a-long-random-secret"
AUTH_JWT_ALGORITHM="HS256"
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_BROWSER_STATE_EXPIRE_SECONDS=300
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"
CHAT_ATTACHMENT_ROOT="/app/backend/data/chat_attachments"

# Feishu app config
FEISHU_APP_ID="cli_xxx"
FEISHU_APP_SECRET="your-feishu-app-secret"
FEISHU_BROWSER_REDIRECT_URI="https://your-domain.example.com/api/v1/auth/feishu/browser/callback"
FEISHU_FRONTEND_AUTH_COMPLETE_URL="https://your-domain.example.com/auth/complete"
FEISHU_OAUTH_SCOPE="contact:contact.base:readonly contact:user.employee_id:readonly"
FEISHU_REQUEST_TIMEOUT_SECONDS=15

# Frontend build-time Feishu config
VITE_FEISHU_APP_ID="cli_xxx"
VITE_FEISHU_SCOPE_LIST=""
VITE_BASE_URL="/"
